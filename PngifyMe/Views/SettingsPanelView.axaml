<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:PngifyMe.Views"
             xmlns:vmh="clr-namespace:PngifyMe.Views.Helper"
             xmlns:lang="clr-namespace:PngifyMe.Lang"
             xmlns:lucideAvalonia="clr-namespace:LucideAvalonia;assembly=LucideAvalonia"
             mc:Ignorable="d" d:DesignWidth="750" d:DesignHeight="600"
             x:Class="PngifyMe.Views.SettingsPanelView">
	<DockPanel>
		<Grid DockPanel.Dock="Top">
			<vmh:ModeSelect/>
			<StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="5">
				<Button x:Name="detachDockButton"
						Click="OnDetachDockClick"
						ToolTip.Tip="{x:Static lang:Resources.ToolTipDetachSettings}"
						Theme="{DynamicResource SolidButton}">
					<StackPanel Orientation="Horizontal" Spacing="5">
						<TextBlock x:Name="detachDockButtonText" Text="{x:Static lang:Resources.DetachSettings}"/>
						<lucideAvalonia:Lucide x:Name="detachDockIcon" Icon="PanelRightOpen" StrokeBrush="White"
											   StrokeThickness="2" Width="22" Height="22"/>
						<lucideAvalonia:Lucide x:Name="dockIcon" Icon="PanelLeftOpen" StrokeBrush="White"
											   StrokeThickness="2" Width="22" Height="22" IsVisible="False"/>
					</StackPanel>
				</Button>
				<Button Click="OnSaveClick"
						ToolTip.Tip="{x:Static lang:Resources.ToolTipSaveChanges}"
						Classes="Primary" Theme="{DynamicResource SolidButton}">
					<StackPanel Orientation="Horizontal" Spacing="5">
						<TextBlock Text="{x:Static lang:Resources.SaveChanges}"/>
						<lucideAvalonia:Lucide Icon="Save" StrokeBrush="White"
											   StrokeThickness="2" Width="22" Height="22"/>
					</StackPanel>
				</Button>
				<Button Click="OnCloseClick"
						ToolTip.Tip="{x:Static lang:Resources.ToolTipCloseSettings}"
						Classes="Warning" Theme="{DynamicResource SolidButton}">
					<StackPanel Orientation="Horizontal" Spacing="5">
						<lucideAvalonia:Lucide Icon="X" StrokeBrush="White"
											   StrokeThickness="2" Width="22" Height="22"/>
					</StackPanel>
				</Button>
			</StackPanel>
		</Grid>
		<StackPanel DockPanel.Dock="Bottom">
			<Rectangle Fill="White" Height="1"/>
			<StackPanel Orientation="Horizontal" Spacing="10"
						PointerPressed="OnTwitchPressed"
						ToolTip.Tip="{x:Static lang:Resources.ToolTipTwitchStatus}">
				<TextBlock Text="{x:Static lang:Resources.TwitchStatus}"/>
				<TextBlock x:Name="twitchStatus" Text="{x:Static lang:Resources.NotConnected}"/>
			</StackPanel>
		</StackPanel>
		<TabControl x:Name="tabs" Grid.Row="1" WrapSelection="True"
					TabStripPlacement="Right" Padding="0">
			<TabItem FontSize="12" Width="125">
				<TabItem.Header>
					<StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
						<TextBlock VerticalAlignment="Center" Text="{x:Static lang:Resources.Microphone}"/>
						<lucideAvalonia:Lucide Icon="Mic" StrokeBrush="White" StrokeThickness="2" Width="22" Height="22"/>
					</StackPanel>
				</TabItem.Header>
				<views:VolumeSlider/>
			</TabItem>
			<TabItem FontSize="12" Width="125">
				<TabItem.Header>
					<StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
						<TextBlock VerticalAlignment="Center" Text="{x:Static lang:Resources.LayoutMenu}"/>
						<lucideAvalonia:Lucide Icon="LayoutGrid" StrokeBrush="White" StrokeThickness="2" Width="22" Height="22"/>
					</StackPanel>
				</TabItem.Header>
				<views:LayoutMenu/>
			</TabItem>
			<TabItem FontSize="12" Width="125">
				<TabItem.Header>
					<StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
						<TextBlock VerticalAlignment="Center" Text="{x:Static lang:Resources.LayerSetup}"/>
						<lucideAvalonia:Lucide Icon="Layers" StrokeBrush="White" StrokeThickness="2" Width="22" Height="22"/>
					</StackPanel>
				</TabItem.Header>
				<views:LayerSetup/>
			</TabItem>
			<TabItem FontSize="12" Width="125">
				<TabItem.Header>
					<StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
						<TextBlock VerticalAlignment="Center" Text="{x:Static lang:Resources.Avatar}"/>
						<lucideAvalonia:Lucide Icon="User" StrokeBrush="White" StrokeThickness="2" Width="22" Height="22"/>
					</StackPanel>
				</TabItem.Header>
				<views:AvatarSetup/>
			</TabItem>
			<TabItem FontSize="12" Width="125">
				<TabItem.Header>
					<StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
						<TextBlock VerticalAlignment="Center" Text="{x:Static lang:Resources.Throwing}"/>
						<lucideAvalonia:Lucide Icon="Anchor" StrokeBrush="White" StrokeThickness="2" Width="22" Height="22"/>
					</StackPanel>
				</TabItem.Header>
				<views:TITSSetup/>
			</TabItem>
			<TabItem FontSize="12" Width="125">
				<TabItem.Header>
					<StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
						<TextBlock VerticalAlignment="Center" Text="{x:Static lang:Resources.TTSPet}"/>
						<lucideAvalonia:Lucide Icon="Squirrel" StrokeBrush="White" StrokeThickness="2" Width="22" Height="22"/>
					</StackPanel>
				</TabItem.Header>
				<views:LLMSetup/>
			</TabItem>
			<TabItem FontSize="12" Width="125">
				<TabItem.Header>
					<StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
						<TextBlock VerticalAlignment="Center" Text="{x:Static lang:Resources.Profiles}"/>
						<lucideAvalonia:Lucide Icon="Users" StrokeBrush="White" StrokeThickness="2" Width="22" Height="22"/>
					</StackPanel>
				</TabItem.Header>
				<views:ProfileSetup/>
			</TabItem>
			<TabItem FontSize="12" Width="125">
				<TabItem.Header>
					<StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
						<TextBlock VerticalAlignment="Center" Text="{x:Static lang:Resources.General}"/>
						<lucideAvalonia:Lucide Icon="Cog" StrokeBrush="White" StrokeThickness="2" Width="22" Height="22"/>
					</StackPanel>
				</TabItem.Header>
				<views:GeneralSettings/>
			</TabItem>
			<TabItem FontSize="12" Width="125">
				<TabItem.Header>
					<StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
						<TextBlock VerticalAlignment="Center" Text="{x:Static lang:Resources.Credits}"/>
						<lucideAvalonia:Lucide Icon="Copyright" StrokeBrush="White" StrokeThickness="2" Width="22" Height="22"/>
					</StackPanel>
				</TabItem.Header>
				<views:CreditsAndInfo/>
			</TabItem>
			<TabItem FontSize="12" Width="125">
				<TabItem.Header>
					<StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
						<TextBlock VerticalAlignment="Center" Text="Logs"/>
						<lucideAvalonia:Lucide Icon="Logs" StrokeBrush="White" StrokeThickness="2" Width="22" Height="22"/>
					</StackPanel>
				</TabItem.Header>
				<views:LogViewer/>
			</TabItem>
		</TabControl>
	</DockPanel>
</UserControl>
